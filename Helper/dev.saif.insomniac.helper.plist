<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Must match the file name (minus .plist) and the Mach service. -->
	<key>Label</key>
	<string>dev.saif.insomniac.helper</string>

	<!-- Path to the helper executable, relative to the app bundle. -->
	<key>BundleProgram</key>
	<string>Contents/MacOS/dev.saif.insomniac.helper</string>

	<!-- The Mach service the app connects to over XPC. -->
	<key>MachServices</key>
	<dict>
		<key>dev.saif.insomniac.helper</key>
		<true/>
	</dict>

	<!-- Ties this daemon's lifecycle to the app for SMAppService. -->
	<key>AssociatedBundleIdentifiers</key>
	<array>
		<string>dev.saif.insomniac</string>
	</array>
</dict>
</plist>
